{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "e2e": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "unitTest": {
      "dependsOn": ["^unitTest"],
      "outputs": []
    },
    "integrationTest": {
      "dependsOn": ["^integrationTest"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    }
  }
}
